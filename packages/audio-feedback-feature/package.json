{
  "name": "@agentdev/audio-feedback-feature",
  "version": "0.1.0",
  "description": "Audio feedback feature for AgentDev - plays sound notifications on call completion",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && npm run copy-assets",
    "dev": "tsup --watch",
    "copy-assets": "node scripts/copy-assets.mjs",
    "prepublishOnly": "npm run build"
  },
  "tsup": {
    "entry": ["src/index.ts"],
    "format": "esm",
    "dts": true,
    "clean": true,
    "sourcemap": true,
    "external": []
  },
  "peerDependencies": {
    "agentdev": ">=0.1.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.3.5",
    "typescript": "^5.3.3",
    "agentdev": "file:../.."
  },
  "keywords": [
    "agentdev",
    "feature",
    "audio-feedback"
  ],
  "license": "MIT"
}
