{
  "name": "@agentdev/visual-feature",
  "version": "0.1.0",
  "description": "Visual understanding feature for AgentDev - provides window capture and vision model analysis",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && npm run copy-assets",
    "dev": "tsup --watch",
    "copy-assets": "node scripts/copy-assets.mjs",
    "prepublishOnly": "npm run build"
  },
  "tsup": {
    "entry": ["src/index.ts", "src/templates/*.render.ts"],
    "format": "esm",
    "dts": true,
    "clean": true,
    "sourcemap": true
  },
  "peerDependencies": {
    "agentdev": ">=0.1.0"
  },
  "dependencies": {
    "openai": "^4.73.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.3.5",
    "typescript": "^5.3.3",
    "agentdev": "file:../.."
  },
  "keywords": [
    "agentdev",
    "feature",
    "visual",
    "vision",
    "screenshot",
    "window"
  ],
  "license": "MIT"
}
