{
  "name": "agentdev",
  "version": "0.2.5",
  "description": "A lightweight, decoupled AI agent framework with built-in debugger",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentdev-viewer": "dist/cli/viewer.cmd",
    "agentdev-server": "dist/cli/server.cmd",
    "agentdev-create-feature": "dist/create-feature-cli.cmd"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bundleDependencies": [
    "@sliverp/qqbot"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-feature-skills.mjs && node scripts/generate-bin-cmds.mjs",
    "dev": "tsup --watch",
    "test": "tsx src/test/test-runner.ts",
    "test:openai-responses": "tsx src/test/openai-responses.test.ts",
    "prepublishOnly": "npm run build",
    "create-feature": "node dist/create-feature-cli.js",
    "copy-example": "node scripts/copy-example-feature.mjs",
    "server": "node dist/cli/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@openai/agents": "^0.4.6",
    "@sliverp/qqbot": "1.5.5",
    "better-sqlite3": "^12.8.0",
    "diff": "^8.0.3",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.0",
    "open": "^11.0.0",
    "openai": "^4.73.0",
    "sharp": "^0.33.5",
    "sound-play": "^1.1.0",
    "undici": "^7.25.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-types": "^3.18.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "tsup": "^8.3.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "openai",
    "anthropic",
    "mcp",
    "debugger"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/agentdev.git"
  },
  "license": "MIT",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "test"
  },
  "author": "",
  "bugs": {
    "url": "https://github.com/your-org/agentdev/issues"
  },
  "homepage": "https://github.com/your-org/agentdev#readme"
}
