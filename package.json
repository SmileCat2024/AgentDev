{
  "name": "agentdev",
  "version": "0.1.0",
  "description": "A lightweight, decoupled AI agent framework with built-in debugger",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentdev-viewer": "dist/cli/viewer.cmd",
    "agentdev-server": "dist/cli/server.cmd"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node scripts/generate-bin-cmds.mjs",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "create-feature": "node packages/create-feature/dist/cli.js",
    "copy-example": "node scripts/copy-example-feature.mjs",
    "server": "node dist/cli/server.js"
  },
  "tsup": {
    "entry": [
      "src/index.ts",
      "src/cli/viewer.ts",
      "src/cli/server.ts"
    ],
    "format": "esm",
    "dts": true,
    "clean": true,
    "sourcemap": true,
    "assets": [
      "src/**/*",
      "!src/**/*.ts",
      "!src/**/*.tsx"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@openai/agents": "^0.4.6",
    "diff": "^8.0.3",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.0",
    "open": "^11.0.0",
    "openai": "^4.73.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "tsup": "^8.3.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "openai",
    "anthropic",
    "mcp",
    "debugger"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/agentdev.git"
  },
  "license": "MIT"
}
