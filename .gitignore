# 依赖目录
node_modules/

# 编译输出目录
dist/
build/
out/

# TypeScript 编译生成的文件（仅在 src/ 目录下）
src/**/*.js
src/**/*.js.map
src/**/*.d.ts
src/**/*.d.ts.map

# IDE/编辑器配置
.vscode/
.idea/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 操作系统生成的文件
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
ehthumbs_vista.db

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 环境变量文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 测试覆盖率文件
coverage/
*.lcov

# 临时文件
tmp/
temp/
test-example/
.trash/

# Claude Code 本地配置（用户专属，不应提交）
.claude/

# 包管理器文件
package-lock.json
yarn.lock
pnpm-lock.yaml

# 运行时数据
pids/
*.pid
*.seed
*.pid.lock

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Desktop App - 忽略打包产物和依赖，但保留源代码
desktop/dist/
desktop/node_modules/
desktop/package-lock.json
desktop/*.js.bak
desktop/*.tmp
desktop/nul

# 特定于项目的目录
docs/
.agentdev/
config/
CLAUDE.md
pyproject.toml
requirements.txt
uv.lock
src/features/visual/python/__pycache__
