# npm package - 通过 package.json "files" 字段控制
# "files": ["dist", "README.md", "LICENSE"]
# .npmignore 只需要排除 dist/ 之外不需要的内容

# 源码和开发文件
src/
examples/
scripts/
desktop/
packages/
test/

# 开发配置
tsconfig.json
.prettierrc*
.eslintrc*

# 依赖
node_modules/

# 构建中间文件
*.tsbuildinfo

# 临时文件
*.log
.tmp/
temp/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 本地配置
.env*
.gitignore

# 技能文档（用户项目自己的）
.claude/
.agentdev
