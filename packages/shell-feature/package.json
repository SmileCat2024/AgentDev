{
  "name": "@agentdev/shell-feature",
  "version": "0.1.0",
  "description": "Shell execution feature for AgentDev - provides bash execution and safe trash operations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "tsup": {
    "entry": ["src/index.ts", "src/templates/*.render.ts"],
    "format": "esm",
    "dts": true,
    "clean": true,
    "sourcemap": true
  },
  "peerDependencies": {
    "agentdev": ">=0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.3.5",
    "typescript": "^5.3.3",
    "agentdev": "file:../.."
  },
  "keywords": [
    "agentdev",
    "feature",
    "shell",
    "bash",
    "trash"
  ],
  "license": "MIT"
}
